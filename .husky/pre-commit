# Pre-commit hook to prevent deployment-blocking errors
echo "🔍 Running pre-commit checks..."

# 1. Check for CSS syntax errors
echo "  ├─ Checking CSS syntax..."
cd apps/web
if pnpm exec stylelint "src/**/*.css" --quiet 2>/dev/null; then
  echo "  ✓ CSS syntax valid"
else
  echo "  ⚠️  CSS linting skipped (stylelint not installed)"
fi

# 2. TypeScript type check (only on staged TS files; skip known pre-existing errors)
echo "  ├─ Type checking..."
if git diff --cached --name-only | grep -qE "\.tsx?$"; then
  TS_ERRORS=$(pnpm tsc --noEmit 2>&1 | grep "error TS" | grep -v "__tests__\|\.test\.\|\.spec\.\|shared-kernel\|/mcp/\|ingest/route\|events/stream\|gcp-secrets\|gcs-client\|traffic-light")
  if echo "$TS_ERRORS" | grep -q "error TS"; then
    echo "  ✗ TypeScript errors found!"
    echo "$TS_ERRORS"
    echo "  Run 'pnpm tsc --noEmit' to see details"
    exit 1
  else
    echo "  ✓ No TypeScript errors"
  fi
else
  echo "  ✓ Skipped Type checking (no TS/TSX files staged)"
fi

# 3. ESLint check (auto-fixable issues)
echo "  ├─ Linting code..."
if git diff --cached --name-only | grep -qE "\.tsx?$"; then
  if pnpm exec eslint "src/**/*.{ts,tsx}" --ignore-pattern "**/__tests__/**" --ignore-pattern "**/*.test.{ts,tsx}" --ignore-pattern "**/*.spec.{ts,tsx}" --max-warnings=0 --quiet 2>/dev/null; then
    echo "  ✓ Code linting passed"
  else
    echo "  ⚠️  Some linting issues found (auto-fixing...)"
    pnpm exec eslint "src/**/*.{ts,tsx}" --fix --quiet 2>/dev/null || true
  fi
else
  echo "  ✓ Skipped Linting code (no TS/TSX files staged)"
fi

# 4. Check for common deployment blockers
echo "  ├─ Checking for common issues..."

# Check for invalid CSS properties
if grep -r "justify-center\|align-content-center\|flex-direction-row-reverse" apps/web/src/styles/*.css 2>/dev/null; then
  echo "  ✗ Invalid CSS properties found!"
  exit 1
fi

# 5. Run tests (fast bail on first failure)
echo "  ├─ Running tests..."
if pnpm test --bail --passWithNoTests 2>&1 | tail -5; then
  echo "  ✓ Tests passed"
else
  echo "  ✗ Tests failed! Fix before committing."
  exit 1
fi

echo "  └─ ✓ All checks passed!"
echo ""
echo "✅ Pre-commit checks complete. Proceeding with commit..."
