        "auth": { "required": true, "roles": ["CLINICIAN"], "rbac": "createProtectedRoute" },
        "phi": { "required": false },
        "rateLimit": { "perMinute": 30 },
        "requestSchema": {
          "type": "object",
          "properties": {
            "locale": { "type": "string", "enum": ["pt-BR", "es-CO", "en"], "default": "pt-BR" },
            "domain": { "type": "string", "enum": ["ALL", "depression", "anxiety", "diabetes", "cardiovascular"], "default": "ALL" }
          }
        },
        "responseSchema": {
          "type": "object",
          "properties": {
            "instruments": { "type": "array", "description": "Structure matches screening-instruments.json format", "items": { "type": "object" } }
          }
        }
      },
      {
        "method": "POST",
        "path": "/api/prevention/gov-submit",
        "description": "Submit prevention/immunization data to government system (RNDS stub). Returns success in sandbox, logs in production.",
        "auth": { "required": true, "roles": ["CLINICIAN", "ORG_ADMIN"], "rbac": "createProtectedRoute" },
        "phi": { "required": true, "header": "X-Access-Reason", "validReasons": ["TREATMENT", "PUBLIC_HEALTH"] },
        "rateLimit": { "perMinute": 10 },
        "invariants": {
          "ruth": "Government submissions must include valid CNS (15-digit) for patient. Data format must comply with RNDS BRImunobiologicoAdministrado or BRRegistroAtendimentoClinico profile.",
          "cyrus": "Requires e-CNPJ digital certificate for production RNDS. Sandbox uses test credentials. All submissions logged in AuditLog with action=GOV_SUBMIT."
        },
        "requestSchema": {
          "type": "object",
          "required": ["system", "resourceType", "fhirBundle"],
          "properties": {
            "system": { "type": "string", "enum": ["RNDS", "ESUS", "RIPS"], "description": "Target government system" },
            "resourceType": { "type": "string", "enum": ["Immunization", "Encounter", "Observation"], "description": "FHIR resource type being submitted" },
            "fhirBundle": { "type": "object", "description": "FHIR R4 Bundle matching government-integration-specs.json and fhir-resource-templates.json" },
            "sandbox": { "type": "boolean", "default": true, "description": "Use homologation/sandbox environment" }
          }
        },
        "responseSchema": {
          "type": "object",
          "properties": {
            "success": { "type": "boolean" },
            "system": { "type": "string" },
            "submissionId": { "type": "string" },
            "status": { "type": "string", "enum": ["SUBMITTED", "VALIDATED", "REJECTED", "STUB_OK"] },
            "errors": { "type": "array", "items": { "type": "object", "properties": { "code": { "type": "string" }, "message": { "type": "string" }, "field": { "type": "string" } } } },
            "note": { "type": "string", "default": "Stub implementation — production RNDS integration pending e-CNPJ certificate setup" }
          }
        }
      }
    ]
  }
}
