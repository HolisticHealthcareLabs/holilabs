        { "id": "phq9_q6", "text": { "en": "Feeling bad about yourself — or that you are a failure or have let yourself or your family down", "pt-BR": "Sentir-se mal consigo mesmo(a) — ou que é um fracasso ou que decepcionou sua família", "es": "Sentirse mal consigo mismo/a — o que es un fracaso o ha decepcionado a su familia" } },
        { "id": "phq9_q7", "text": { "en": "Trouble concentrating on things, such as reading the newspaper or watching television", "pt-BR": "Dificuldade para se concentrar nas coisas, como ler jornal ou ver televisão", "es": "Dificultad para concentrarse en las cosas, como leer el periódico o ver televisión" } },
        { "id": "phq9_q8", "text": { "en": "Moving or speaking so slowly that other people could have noticed? Or the opposite — being so fidgety or restless that you have been moving around a lot more than usual", "pt-BR": "Mover-se ou falar tão devagar que as outras pessoas puderam perceber? Ou o contrário — estar tão agitado(a) que se mexeu muito mais que o habitual", "es": "Moverse o hablar tan lento que otras personas lo notaron? O lo contrario — estar tan inquieto/a que se movió mucho más de lo habitual" } },
