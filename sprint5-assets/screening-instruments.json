        { "id": "phq9_q2", "text": { "en": "Feeling down, depressed, or hopeless", "pt-BR": "Sentir-se para baixo, deprimido(a) ou sem esperança", "es": "Sentirse desanimado/a, deprimido/a o sin esperanza" } },
        { "id": "phq9_q3", "text": { "en": "Trouble falling or staying asleep, or sleeping too much", "pt-BR": "Dificuldade para pegar no sono ou permanecer dormindo, ou dormir demais", "es": "Dificultad para dormir o permanecer dormido/a, o dormir demasiado" } },
