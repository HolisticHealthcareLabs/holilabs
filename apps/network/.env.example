# ============================================================
# @holi/network — Environment Variables
# Copy to .env.local and fill in all values before running.
# CYRUS: Never commit real values. Add .env.local to .gitignore.
# ============================================================

# --- Database (shared with monorepo) ---
DATABASE_URL="postgresql://user:password@localhost:5432/holilabs?schema=public"

# --- Meta WhatsApp Cloud API ---
META_PHONE_NUMBER_ID="your_phone_number_id"
META_ACCESS_TOKEN="your_access_token"
META_APP_SECRET="your_app_secret"
META_WEBHOOK_VERIFY_TOKEN="your_random_verify_token"

# --- Cal.com ---
CALCOM_API_KEY="cal_live_xxxxxxxxxxxxxxxxxxxx"
CALCOM_BASE_URL="https://api.cal.com/v2"

# --- PHI Encryption (AES-256-GCM, 32 bytes = 64 hex chars) ---
# Generate with: openssl rand -hex 32
PHI_ENCRYPTION_KEY_VERSION="1"
PHI_ENCRYPTION_KEY_V1="000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f"

# --- Auth ---
# Shared NEXTAUTH_SECRET from apps/web (used to verify clinician sessions)
NEXTAUTH_SECRET="your_nextauth_secret_here"
# Legacy machine-to-machine API key (optional — prefer session tokens in production)
NETWORK_API_KEY="your_random_api_key_here"

# --- Phone Lookup ---
# HMAC secret for patient phone index. Must NOT equal PHI_ENCRYPTION_KEY_V1.
# Generate with: openssl rand -hex 32
PHONE_LOOKUP_SECRET="a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2"

# --- Cron ---
# Secret for /api/cron/expire-referrals (passed as Bearer or X-Cron-Secret header)
CRON_SECRET="your_cron_secret_here"

# --- Cal.com Webhooks ---
CALCOM_WEBHOOK_SECRET="your_calcom_webhook_secret"

# --- Demo ---
DEMO_ORG_ID="demo-org"
