[
    {
        "ruleId": "DOAC_SAFETY_AGE_001",
        "name": "DOAC Dose Review for Elderly Patients (Age ≥ 80) — Rivaroxaban",
        "domain": "DOAC_SAFETY",
        "severity": "FLAG",
        "provenance": {
            "sourceAuthority": "European Heart Rhythm Association",
            "sourceDocument": "EHRA Practical Guide on the use of NOACs in patients with NVAF, 2021 update",
            "sourceVersion": "2021-update",
            "effectiveDate": "2021-04-25",
            "jurisdiction": "INTL",
            "citationUrl": "https://doi.org/10.1093/europace/euab065",
            "licenseType": "proprietary"
        },
        "logic": {
            "and": [
                {
                    ">=": [
                        {
                            "var": "patient_age"
                        },
                        80
                    ]
                },
                {
                    "or": [
                        {
                            "==": [
                                {
                                    "var": "proposed_medication"
                                },
                                "rivaroxaban"
                            ]
                        },
                        {
                            "==": [
                                {
                                    "var": "proposed_medication"
                                },
                                "xarelto"
                            ]
                        }
                    ]
                }
            ]
        },
        "intervention": {
            "message": "Patient is ≥ 80 years old. Elderly patients have increased bleeding risk with rivaroxaban due to age-related renal decline and pharmacokinetic changes.",
            "recommendation": "Consider reduced dose (15mg QD for AF, 10mg QD for VTE prophylaxis). Assess renal function. Monitor closely for bleeding."
        },
        "tags": [
            "doac",
            "elderly",
            "age-adjustment",
            "rivaroxaban"
        ]
    },
