[
    {
        "ruleId": "DOAC_SAFETY_WEIGHT_001",
        "name": "DOAC Dose Review for Low Body Weight (< 60kg) — Apixaban",
        "domain": "DOAC_SAFETY",
        "severity": "FLAG",
        "provenance": {
            "sourceAuthority": "European Heart Rhythm Association",
            "sourceDocument": "EHRA Practical Guide on the use of NOACs in patients with NVAF, 2021 update",
            "sourceVersion": "2021-update",
            "effectiveDate": "2021-04-25",
            "jurisdiction": "INTL",
            "citationUrl": "https://doi.org/10.1093/europace/euab065",
            "licenseType": "proprietary"
        },
        "logic": {
            "and": [
                {
                    "<": [
                        {
                            "var": "patient_weight"
                        },
                        60
                    ]
                },
                {
                    "or": [
                        {
                            "==": [
                                {
                                    "var": "proposed_medication"
                                },
                                "apixaban"
                            ]
                        },
                        {
                            "==": [
                                {
                                    "var": "proposed_medication"
                                },
                                "eliquis"
                            ]
                        }
                    ]
                }
            ]
        },
        "intervention": {
            "message": "Patient weighs < 60kg. Weight ≤ 60kg is one of the 3 dose-reduction criteria for apixaban (age ≥ 80, weight ≤ 60kg, creatinine ≥ 1.5 mg/dL). If 2 of 3 criteria are met, reduce to 2.5mg BID.",
            "recommendation": "Evaluate all 3 dose-reduction criteria. If ≥ 2 are met, reduce dose to 2.5mg BID. Document weight and assessment."
        },
        "tags": [
            "doac",
            "low-weight",
            "weight-adjustment",
            "apixaban"
        ]
    },
